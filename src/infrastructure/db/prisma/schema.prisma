generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════════════════════
// Portal Panorama — schema Fase 9 (modelo nuevo: Place sin tipo + Event separado)
//
// Decisiones de diseño en PLAN_FASE9.md → "Etapa 2 — decisiones de diseño":
//   2.1 limpio + puertas baratas (sin Flow/Claim/Feed/Analytics)
//   2.2 categoría secundaria = 4 FKs en Place
//   2.3 tags 6 capas (rediseño 2026-06-14) = una tabla Tag + layer (límites/exclusiones en dominio)
//   2.4 Review polimórfico (targetType+targetId), escala 1–5, apagado en MVP
//   2.5 score = promedio bayesiano (m=50), recalculado al cargar/editar
//   2.6 colores del Metro corregidos (L3 café / L6 morada)
//
// IDs de dominio = CUID2 generados en la app (`id String @id`, sin default).
// Los modelos de Auth.js conservan @default(cuid()) porque los crea el adapter.
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

// 5 buckets (incluye Gratis) — C6. El filtro "¿Cuánto gasto?" mapea a esto.
enum PriceRange {
  FREE
  UNDER_5000
  FROM_5000_TO_15000
  FROM_15000_TO_30000
  OVER_30000
}

// ¿reserva o solo llegar? (campo operacional de la ficha, B/entregable 2).
// ÚNICA fuente de verdad de la reserva: NO existe tag "con/sin reserva" (se quitó
// la redundancia). El filtro "Sin reserva" se deriva de `reservation = WALK_IN`.
enum ReservationPolicy {
  REQUIRED
  WALK_IN
  RECOMMENDED
}

// Solo aplica a categorías al aire libre (refinamiento D, input/)
enum RainPolicy {
  SUSPENDED
  RELOCATED
  CONTINUES
}

enum PlaceStatus {
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
}

// Sistema de 6 capas (2.3, rediseño 2026-06-14). Universal si Tag.categoryId == null;
// condicional a una categoría si está seteado (ej. "tipo de cocina" → Gastronomía).
enum TagLayer {
  AUDIENCE // ¿con quién? (máx 4 por ficha, en dominio)
  OCCASION // ideal para / ocasión (máx 3 por ficha, en dominio)
  VIBE // vibe / ambiente (máx 3 por ficha, en dominio)
  EXPERIENCE // qué ofrece de destacable: rooftop, vista, vida nocturna… (sin tope)
  SERVICE // servicios y acceso: estacionamiento, wifi, accesible, pet friendly… (sin tope)
  SPECIFIC // atributos específicos condicionales por categoría (sin tope)
  CUISINE // tipo de comida (cocina + plato), condicional a Gastronomía (sin tope)
}

// Objetivo reseñado extensible (2.4): hoy PLACE; DISH/EVENT entran sin tocar el schema.
enum ReviewTarget {
  PLACE
  DISH
  EVENT
}

enum ReportReason {
  WRONG_INFO
  CLOSED
  DUPLICATE
  OTHER
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

// Sugerencias / feedback general del público (no atado a un lugar puntual).
enum SuggestionKind {
  FALTA_LUGAR // "falta este lugar / agreguen X"
  FOTO // "la foto está mal / mejorable"
  INFO // "me gustaría ver esta info"
  OTRO
}

enum SuggestionStatus {
  OPEN
  RESOLVED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Reclamo de ficha/marca por un negocio (BUSINESS_ACCOUNTS_SPEC.md §4).
enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

// Tipo de lista curada (landing SEO). GUIDE = guía exhaustiva por categoría/comuna
// ("Museos de Santiago"); OCCASION = lista por intención/ocasión ("Para una primera
// cita"), regla sobre tags OCCASION. Solo cambia copy/template, no el mecanismo.
enum CuratedListKind {
  GUIDE
  OCCASION
}

// Nivel de un lugar fijado a mano en una lista. FEATURED = destacado (artículo
// completo arriba de todo); MENTION = mención honorífica (banda compacta con nota
// de una línea, entre los destacados y la grilla).
enum CuratedPinKind {
  FEATURED
  MENTION
}

// ─── Auth.js adapter models ───────────────────────────────────────────────────
// Requeridos por @auth/prisma-adapter. MVP: email + contraseña (passwordHash).
// Google/Apple post-MVP entran por `Account` (OAuth) sin tocar el schema.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Usuario ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id
  email         String    @unique
  name          String
  role          UserRole  @default(USER)
  passwordHash  String?
  // Auth.js required
  emailVerified DateTime?
  image         String?
  // Preferencia opcional (C.3-bis): sube su comuna primero, transparente/desactivable
  homeCommuneId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  homeCommune         Commune?             @relation("HomeCommune", fields: [homeCommuneId], references: [id])
  collections         Collection[]
  visitHistory        VisitHistory[]
  reviews             Review[]
  reports             Report[]
  suggestions         Suggestion[]
  topicSubscriptions  TopicSubscription[]
  ownedPlaces         Place[]              @relation("PlaceOwner")
  ownedBrands         Brand[]              @relation("BrandOwner")
  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  businessProfile     BusinessProfile?
  claims              BusinessClaim[]      @relation("Claimant")
  reviewedClaims      BusinessClaim[]      @relation("ClaimReviewer")

  @@index([homeCommuneId])
}

// ─── Cuenta de negocio (BUSINESS_ACCOUNTS_SPEC.md §4 + §6, sesión 28) ────────────
// "El sombrero de negocio" de un User (1:1 opcional): un User normal no lo tiene;
// lo obtiene al aprobarse su reclamo o al registrarse como negocio. No posee lugares
// directamente — la propiedad vive en Place.ownerId / Brand.ownerId (→ User).

model BusinessProfile {
  id              String    @id
  userId          String    @unique
  legalName       String? // razón social (opcional, sin fricción)
  rut             String? // opcional; se valida con el VO de dígito verificador al setear
  contactEmail    String?
  contactPhone    String?
  // Opt-in de correos de novedades (s28): permite anunciar funcionalidades nuevas.
  newsletterOptIn Boolean   @default(false)
  verifiedAt      DateTime? // null = aún no verificado por el admin
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Un reclamo de propiedad sobre un Place (dueño de una sucursal) o una Brand
// (cadena) — exactamente uno de los dos; la exclusión la cuida el dominio.
// Al aprobar: se setea el ownerId correspondiente + se crea el BusinessProfile.
model BusinessClaim {
  id           String      @id
  claimantId   String
  placeId      String?
  brandId      String?
  claimantRole String? // dueño / representante / encargado
  message      String?     @db.Text // evidencia en texto
  evidenceUrl  String? // documento opcional
  contactPhone String?
  contactEmail String?
  status       ClaimStatus @default(PENDING)
  reviewedById String?
  reviewNotes  String?     @db.Text
  createdAt    DateTime    @default(now())
  reviewedAt   DateTime?

  claimant   User   @relation("Claimant", fields: [claimantId], references: [id], onDelete: Cascade)
  place      Place? @relation(fields: [placeId], references: [id], onDelete: Cascade)
  brand      Brand? @relation(fields: [brandId], references: [id], onDelete: Cascade)
  reviewedBy User?  @relation("ClaimReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([claimantId])
  @@index([placeId])
  @@index([brandId])
}

// Recuperar contraseña. Se guarda el HASH del token (no el token en claro): un
// dump de la BD no entrega tokens usables. Single-use (usedAt) + expiración corta.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Catálogos geográficos ────────────────────────────────────────────────────

model Commune {
  id            String         @id
  slug          String         @unique
  name          String
  neighborhoods Neighborhood[] // M2M: un barrio puede caer en varias comunas
  places        Place[]
  events        Event[]
  homeUsers     User[]         @relation("HomeCommune")
}

// Un barrio puede pertenecer a >1 comuna (Bellavista = Recoleta + Providencia;
// Barrio Italia = Providencia + Ñuñoa). El Place guarda su comuna exacta aparte;
// el barrio es metadata filtrable independiente. Por eso slug es único global.
model Neighborhood {
  id   String @id
  slug String @unique
  name String

  communes Commune[]
  places   Place[]
  events   Event[]
}

// ─── Catálogo de Metro ────────────────────────────────────────────────────────
// Estación ↔ línea = many-to-many (Baquedano = L1+L5, doble color). Refinamiento E.

model MetroLine {
  id       String         @id
  code     String         @unique // L1, L2, L3, L4, L4A, L5, L6
  name     String
  color    String // hex (2.6): L1 #E1251B · L2 #F5A800 · L3 #8B4513 · L4 #004F9F · L4A #009CDE · L5 #00A651 · L6 #943C93
  stations MetroStation[]
}

model MetroStation {
  id    String      @id
  slug  String      @unique
  name  String
  lat   Float?
  lng   Float?
  lines MetroLine[]

  places Place[]
  events Event[]
}

// ─── Categorías ───────────────────────────────────────────────────────────────
// 8 categorías (rediseño 2026-06-14). `eventOnly` = Shows/Ferias/Talleres: registradas pero
// apagadas hasta encender eventos. `isActive` = se muestra en la UI.

model Category {
  id        String  @id
  slug      String  @unique
  name      String
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  eventOnly Boolean @default(false)

  subcategories   Subcategory[]
  tags            Tag[] // tags condicionales a esta categoría (Tag.categoryId)
  primaryPlaces   Place[]       @relation("PlaceCategory")
  secondaryPlaces Place[]       @relation("PlaceSecondaryCategory")
  events          Event[]
}

model Subcategory {
  id         String @id
  slug       String
  name       String
  categoryId String

  category        Category @relation(fields: [categoryId], references: [id])
  primaryPlaces   Place[]  @relation("PlaceSubcategory")
  secondaryPlaces Place[]  @relation("PlaceSecondarySubcategory")
  events          Event[]

  @@unique([categoryId, slug])
  @@index([categoryId])
}

// ─── Tags (6 capas) ───────────────────────────────────────────────────────────

model Tag {
  id         String   @id
  slug       String   @unique
  name       String
  layer      TagLayer
  // null = universal; seteado = condicional a esa categoría (ej. tipo de cocina)
  categoryId String?

  category Category?  @relation(fields: [categoryId], references: [id])
  places   PlaceTag[]

  @@index([layer])
  @@index([categoryId])
}

model PlaceTag {
  placeId String
  tagId   String

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([placeId, tagId])
  @@index([tagId])
}

// ─── Brand (Negocio / Marca con varias sucursales) ──────────────────────────────
// Entidad paraguas: agrupa las sucursales (Place) de una marca comercial bajo una
// identidad común y, a futuro, su cartelera (Event). Eje ORTOGONAL a parentId
// (contención física) y ownerId (gestión). Una marca puede tener solo Places (hoy),
// solo Events (futuro: productoras), o ambos — por eso brandId va en los dos, no se
// deriva del Place. brandId nullable: la mayoría de las fichas no lo usan. Decisiones
// en BRAND_SPEC.md §10.
model Brand {
  id          String  @id
  slug        String  @unique
  name        String
  logoUrl     String? // rehospedado con el pipeline de imágenes propio (nunca hotlink)
  description String? @db.Text
  website     String?
  instagram   String?
  socialLinks Json? // redes extra: [{ network, url }] (mismo shape que Place)

  // Cuenta que gestiona la marca (self-service). RESERVADO/PARQUEADO: en el MVP la
  // marca la crea el admin y ownerId queda null. Es el puente cuenta↔marca para
  // cuando el dueño se registre y "reclame" su marca. Una cuenta gestiona una o más
  // marcas; equipos (varias cuentas por marca) irían a una tabla de miembros aparte.
  // Ver BRAND_SPEC.md §11. Puerta barata: nullable → se enciende sin migrar.
  ownerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner  User?           @relation("BrandOwner", fields: [ownerId], references: [id])
  places Place[] // sucursales (real hoy)
  events Event[] // cartelera de la marca (reservado; Eventos apagado en MVP)
  claims BusinessClaim[]

  @@index([slug])
  @@index([ownerId])
}

// ─── Place (Lugar) — entidad central del MVP, siempre permanente, sin tipo ──────

model Place {
  id          String  @id
  slug        String  @unique
  name        String
  description String? @db.Text
  menuUrl     String?

  // Categorización (2.2): principal + subcat obligatorias; secundaria opcional
  categoryId             String
  subcategoryId          String
  secondaryCategoryId    String?
  secondarySubcategoryId String?

  // Ubicación
  address        String?
  communeId      String
  neighborhoodId String?
  lat            Float?
  lng            Float?
  metroStationId String?
  accessDetail   String? // "Entrada por Espacio B, 2° piso"
  reference      String? // "frente al Jumbo"
  rainPolicy     RainPolicy? // solo categorías al aire libre

  // Presupuesto / operacional
  priceRange     PriceRange?
  reservation    ReservationPolicy?
  paymentMethods String[] // métodos de pago (informativo, no filtro MVP)
  parkingOptions String[] // dónde estacionar: OWN_FREE | OWN_PAID | STREET_FREE | STREET_PAID | VALET | HARD. Lo puebla Google (enrich); el dueño lo corrige.
  schedule       String?            @db.Text // horario en texto libre (estructurado = puerta abierta)

  // Contacto / redes
  phone       String?
  website     String?
  instagram   String? // red principal (pilar de crecimiento); va aparte por su trato especial en la ficha
  socialLinks Json? // redes extra: [{ network, url }] (WhatsApp/Facebook/TikTok…). Informativo, no filtrable.

  // Reputación Google (B.7) + score calculado (2.5, promedio bayesiano)
  googlePlaceId     String? @unique
  googleRating      Float?
  googleReviewCount Int?
  score             Float   @default(0)

  // Propiedad / estado (puertas baratas, 2.1) — todo lo carga el admin en MVP
  isPremium Boolean     @default(false)
  ownerId   String?
  status    PlaceStatus @default(PENDING_REVIEW)

  // Lugar contenedor (padre-hijo): un Place puede agrupar a otros Places-con-ficha
  // (Parquemet → Cerro/Zoo). Self-relation cardinalidad 1; archivar el padre NO
  // borra los hijos (SetNull). El anti-ciclo lo cuida el dominio + use case.
  parentId String?

  // Marca/Negocio (eje comercial): la sucursal cuelga de una Brand. Borrar la marca
  // NO borra los locales (SetNull). Ortogonal a parentId/ownerId. Ver BRAND_SPEC.md.
  brandId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category             Category      @relation("PlaceCategory", fields: [categoryId], references: [id])
  subcategory          Subcategory   @relation("PlaceSubcategory", fields: [subcategoryId], references: [id])
  secondaryCategory    Category?     @relation("PlaceSecondaryCategory", fields: [secondaryCategoryId], references: [id])
  secondarySubcategory Subcategory?  @relation("PlaceSecondarySubcategory", fields: [secondarySubcategoryId], references: [id])
  commune              Commune       @relation(fields: [communeId], references: [id])
  neighborhood         Neighborhood? @relation(fields: [neighborhoodId], references: [id])
  metroStation         MetroStation? @relation(fields: [metroStationId], references: [id])
  owner                User?         @relation("PlaceOwner", fields: [ownerId], references: [id])
  parent               Place?        @relation("PlaceContainer", fields: [parentId], references: [id], onDelete: SetNull)
  children             Place[]       @relation("PlaceContainer")
  brand                Brand?        @relation(fields: [brandId], references: [id], onDelete: SetNull)

  images          PlaceImage[]
  points          PlacePoint[]
  tags            PlaceTag[]
  events          Event[]
  collectionItems CollectionItem[]
  curatedPins     CuratedListPin[]
  visitHistory    VisitHistory[]
  reports         Report[]
  claims          BusinessClaim[]
  clicks          PlaceClick[]

  @@index([status])
  @@index([categoryId, status])
  @@index([communeId, status])
  @@index([neighborhoodId, status])
  @@index([metroStationId])
  @@index([priceRange, status])
  @@index([score(sort: Desc)])
  @@index([ownerId])
  @@index([parentId])
  @@index([brandId])
}

// Spot SIN ficha (mirador, kiosco, "el local donde venden X"): contenido editorial
// que cuelga de CUALQUIER Place (incluido un hijo). Sin filtro/reseña/link — solo
// se lista bajo "Qué hay en [X]". Tabla (no JSON) para editarlos como filas.
model PlacePoint {
  id          String  @id
  placeId     String
  name        String
  description String? @db.Text
  kind        String? // etiqueta libre opcional ("mirador", "kiosco")
  sortOrder   Int     @default(0)

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId, sortOrder])
}

model PlaceImage {
  id        String  @id
  placeId   String
  url       String // storage propio (nunca base64/hotlink)
  alt       String?
  credit    String? // crédito / origen
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId, sortOrder])
}

// ─── Event — en el schema desde ya, APAGADO en el MVP ───────────────────────────

model Event {
  id          String  @id
  slug        String  @unique
  name        String
  description String? @db.Text

  placeId       String? // nullable: evento sin local fijo (concierto en parque, feria)
  // Marca/Negocio que organiza el evento. RESERVADO mientras Eventos sigue apagado.
  // Combina con placeId: (brand,place)=evento de marca en su sucursal · (brand,—)=
  // evento brand-wide · (—,place)=evento de un local suelto. Ver BRAND_SPEC.md §10.
  brandId       String?
  categoryId    String // puede diferir de la del local (un bar que hace teatro)
  subcategoryId String?

  // Dimensión temporal
  startsAt       DateTime
  doorsAt        DateTime?
  durationMin    Int?
  isRecurring    Boolean   @default(false)
  recurrenceRule String? // sabor recurrente (taller cada sábado) — se trabaja con eventos
  expiresAt      DateTime? // se archiva el día siguiente de su fecha (historial del local)

  // Acceso / tickets / canales
  ticketUrl       String?
  officialChannel String?
  website         String?
  instagram       String?

  // Apto (campos propios del evento)
  familyFriendly Boolean?
  kidsFriendly   Boolean?
  romantic       Boolean?

  // Ubicación propia (puede heredar del place o ser independiente)
  address        String?
  communeId      String?
  neighborhoodId String?
  lat            Float?
  lng            Float?
  metroStationId String?

  status    EventStatus @default(DRAFT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  place        Place?        @relation(fields: [placeId], references: [id])
  brand        Brand?        @relation(fields: [brandId], references: [id], onDelete: SetNull)
  category     Category      @relation(fields: [categoryId], references: [id])
  subcategory  Subcategory?  @relation(fields: [subcategoryId], references: [id])
  commune      Commune?      @relation(fields: [communeId], references: [id])
  neighborhood Neighborhood? @relation(fields: [neighborhoodId], references: [id])
  metroStation MetroStation? @relation(fields: [metroStationId], references: [id])

  @@index([placeId])
  @@index([brandId])
  @@index([status, startsAt])
  @@index([categoryId, status])
}

// ─── Colecciones — una entidad para listas de usuario Y listas curadas ──────────

// Lista MANUAL del usuario (guardar lugares). Las listas curadas públicas YA NO
// viven acá: son `CuratedList` (regla guardada + landing SEO). `ownerId` es
// obligatorio: toda Collection pertenece a un usuario.
model Collection {
  id          String   @id
  name        String
  ownerId     String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@index([ownerId])
}

// ─── Lista curada = "lista inteligente" (landing SEO de guía/ocasión) ────────────
// NO es una lista de lugares elegidos a mano: es una REGLA guardada (los filtros del
// explorar, en `rule`) que se resuelve al leerla con SearchService → se mantiene
// completa sola a medida que se carga el catálogo. Encima, chrome editorial (intro
// tipo blog, portada) + destacados fijados a mano (`pins`) que van primero con su
// propia bajada. Decisión: PLAN.md backlog (d) (2026-06-25).
model CuratedList {
  id            String          @id
  slug          String          @unique // landing: /lista/[slug]
  name          String // <h1> de la landing
  kind          CuratedListKind @default(GUIDE)
  description   String?         @db.Text // bajada corta = meta description (SEO)
  intro         String?         @db.Text // cuerpo editorial tipo blog (texto propio = SEO)
  coverImageUrl String? // hero + imagen de OG al compartir
  rule          Json // subset de SearchParams: { categorySlug?, communeSlug?, priceRanges?, ... }
  sort          String          @default("score_desc") // orden del resto (reservado; hoy solo score desc)
  isPublished   Boolean         @default(false) // borrador = no visible / no indexable
  publishedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  pins CuratedListPin[]

  @@index([isPublished])
}

// Destacado de una lista: lugar fijado a mano que va ARRIBA del resultado de la regla,
// con su bajada editorial ("qué es / qué esperar"). El resto de los datos (foto,
// horario, metro, rating) se leen del Place al vuelo, no se guardan acá.
model CuratedListPin {
  listId    String
  placeId   String
  kind      CuratedPinKind @default(FEATURED) // destacado (artículo) o mención honorífica (banda)
  blurb     String?        @db.Text // "qué es / qué esperar" (texto propio = SEO)
  sortOrder Int            @default(0)

  list  CuratedList @relation(fields: [listId], references: [id], onDelete: Cascade)
  place Place       @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([listId, placeId])
  @@index([placeId])
}

model CollectionItem {
  collectionId String
  placeId      String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  place      Place      @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([collectionId, placeId])
  @@index([placeId])
}

// ─── Historial de visitas (combustible para la IA, post-MVP) ────────────────────

model VisitHistory {
  id        String   @id
  userId    String
  placeId   String
  visitedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([userId, visitedAt(sort: Desc)])
  @@index([placeId])
}

// ─── PlaceClick — intención de contacto (métricas del panel de negocio) ──────────
// Clic ANÓNIMO en un enlace de acción de la ficha: cómo llegar, web, Instagram,
// teléfono, carta, otra red. Es lo que el dueño quiere ver (a diferencia del rating
// de Google, que ya se ve en la ficha). Sin userId: es tráfico público, no historial
// personal — VisitHistory (arriba) es otra cosa (lugares que un usuario marcó).
enum PlaceClickType {
  DIRECTIONS
  WEBSITE
  INSTAGRAM
  PHONE
  MENU
  SOCIAL
}

model PlaceClick {
  id        String         @id
  placeId   String
  type      PlaceClickType
  createdAt DateTime       @default(now())

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId, type])
  @@index([placeId, createdAt(sort: Desc)])
}

// ─── Review (propia, polimórfica) — creada pero APAGADA en el MVP (2.4) ──────────
// Sin FK al objetivo: la integridad referencial la cuida el dominio, no la BD,
// para que sumar Dish/Event no toque el schema.

model Review {
  id         String       @id
  targetType ReviewTarget @default(PLACE)
  targetId   String
  userId     String
  rating     Int // escala 1–5 (alineada con Google) — rango validado en dominio
  body       String?      @db.Text
  response   String?      @db.Text // respuesta del negocio (post-MVP)
  createdAt  DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId, userId])
  @@index([targetType, targetId])
  @@index([userId])
}

// ─── Report — "reportar dato incorrecto / lugar cerrado" (frescura colaborativa) ─

model Report {
  id         String       @id
  placeId    String
  userId     String? // nullable: el visitante también puede reportar
  reason     ReportReason
  message    String?      @db.Text
  status     ReportStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([placeId])
  @@index([status])
}

// ─── Suggestion — "sugerencias" / feedback general del público ────────────────────

model Suggestion {
  id         String           @id
  kind       SuggestionKind   @default(OTRO)
  message    String           @db.Text
  email      String? // opcional: para poder responderle si dejó contacto
  userId     String? // si estaba logueado
  status     SuggestionStatus @default(OPEN)
  createdAt  DateTime         @default(now())
  resolvedAt DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
}

// ─── TopicSubscription — puerta abierta (newsletter + avisos por keyword/tema) ───

model TopicSubscription {
  id        String   @id
  userId    String
  keyword   String // tema o palabra clave (ej. "conciertos de rock")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, keyword])
  @@index([userId])
}
