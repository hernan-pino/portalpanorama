generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  CONSUMER
  BUSINESS_OWNER
  ADMIN
}

enum ListingPlan {
  FREE
  PREMIUM
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  CLAIMED
  SUSPENDED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum TagStatus {
  ACTIVE
  PENDING_APPROVAL
  REJECTED
}

enum FeedItemType {
  NEW_PHOTO
  HOURS_UPDATED
  NEW_REVIEW
  INFO_UPDATED
}

// ─── Auth.js adapter models ───────────────────────────────────────────────────
// Requeridos por @auth/prisma-adapter. Campos extra en User (emailVerified,
// image) son ignorados por los mappers de dominio — solo los usa Auth.js.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain models ────────────────────────────────────────────────────────────

model User {
  id            String    @id
  email         String    @unique
  name          String
  role          UserRole  @default(CONSUMER)
  rut           String?
  passwordHash  String?
  // Auth.js required
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  listings      Listing[]      @relation("ListingOwner")
  favorites     UserFavorite[]
  reviews       Review[]
  claims        ListingClaim[]
  feedItems     FeedItem[]
  subscriptions Subscription[]
  accounts      Account[]
  sessions      Session[]
}

model Category {
  id       String    @id
  slug     String    @unique
  name     String
  listings Listing[]
}

model Listing {
  id                  String        @id
  slug                String        @unique
  name                String
  description         String?       @db.Text
  plan                ListingPlan   @default(FREE)
  status              ListingStatus @default(DRAFT)
  categoryId          String
  neighborhood        String
  address             String?
  phone               String?
  website             String?
  priceRange          Int?
  ownerId             String
  pricePerMonthAmount Int?
  lat               Float?
  lng               Float?
  commune           String?
  businessHours     Json?
  googlePlaceId     String?       @unique
  googleRating      Float?
  googleReviewCount Int?
  attributes        Json?         @db.JsonB
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  category      Category          @relation(fields: [categoryId], references: [id])
  owner         User              @relation("ListingOwner", fields: [ownerId], references: [id])
  images        ListingImage[]
  tags          ListingTag[]
  reviews       Review[]
  googleReviews GoogleReview[]
  claims        ListingClaim[]
  favorites     UserFavorite[]
  subscription  Subscription?
  feedItems     FeedItem[]
  analytics     ListingAnalytics?

  @@index([status])
  @@index([plan, status])
  @@index([categoryId, status])
  @@index([neighborhood, status])
  @@index([commune, status])
  @@index([ownerId])
}

model GoogleReview {
  id          String   @id
  listingId   String
  authorName  String
  rating      Float
  body        String   @db.Text
  publishedAt DateTime

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model ListingImage {
  id        String  @id
  listingId String
  url       String
  alt       String?
  order     Int     @default(0)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, order])
}

model ListingTag {
  id        String    @id
  listingId String
  slug      String
  name      String
  status    TagStatus @default(ACTIVE)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, slug])
  @@index([slug, status])
}

model ListingClaim {
  id         String      @id
  listingId  String
  claimantId String
  status     ClaimStatus @default(PENDING)
  message    String?     @db.Text
  reviewNote String?     @db.Text
  createdAt  DateTime    @default(now())
  resolvedAt DateTime?

  listing  Listing @relation(fields: [listingId], references: [id])
  claimant User    @relation(fields: [claimantId], references: [id])

  @@index([listingId])
  @@index([claimantId])
  @@index([status])
}

model Review {
  id        String   @id
  listingId String
  userId    String
  rating    Int
  body      String   @db.Text
  response  String?  @db.Text
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([listingId, userId])
  @@index([listingId])
  @@index([userId])
}

model Subscription {
  id                  String             @id
  listingId           String             @unique
  userId              String
  status              SubscriptionStatus @default(ACTIVE)
  flowPlanId          String
  flowSubId           String?            @unique
  pricePerMonthAmount Int
  currentPeriodEnd    DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  listing Listing @relation(fields: [listingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UserFavorite {
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([userId, listingId])
}

model FeedItem {
  id        String       @id
  userId    String
  listingId String
  type      FeedItemType
  payload   Json
  read      Boolean      @default(false)
  createdAt DateTime     @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([listingId])
}

// D9: contadores en Postgres, migrable a Plausible/GA sin tocar use cases
model ListingAnalytics {
  listingId  String   @id
  viewCount  Int      @default(0)
  clickCount Int      @default(0)
  updatedAt  DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}
